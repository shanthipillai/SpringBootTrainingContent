package tes.your.coding.arrays;

import java.util.Arrays;

public class ArrayReverse {
	
	
	
	public static int[] reverseAnArray(int arr[], int i, int j)
	{
		
		while(i<j)
		{
			int temp=arr[i];
			arr[i]=arr[j];
			arr[j]=temp;
			i++;
			j--;
		}
		
		return arr;
	}
	
	public void shiftArrayLeft(int arr[], int k)
	{
		int n=arr.length;
		reverseAnArray(arr,n-k-1,n-1);
		
	}
	
