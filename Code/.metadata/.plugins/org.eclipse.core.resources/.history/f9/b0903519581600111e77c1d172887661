//@ConfigurationProperties(prefix="customer")
@Component("cardsservice")
@Data
public class Cards implements InitializingBean, DisposableBean , BeanNameAware 

{

	@Value("${customer.customerName}")
	String customerName;
	@Value("${customer.typeOfCard}")
	String typeOfCard;
	@Value("${customer.digit}")
	String digit;
	Cards()
	{
		System.out.println("Cards Constructor Created");
	}
	
	@Override
	public void setBeanName(String name) {
		System.out.println("Bean name="+name);
	}
	
	@PostConstruct
	public void postConstruct()
	{
		System.out.println("Card Service :: Post Constructor Executed");
		//testing 
		System.out.println("Post Construct"+customerName);
	}
	@PreDestroy
	public void preDestroy()
	{
		System.out.println("Card Service Pre destroyed");
	}

	@Override
	public void destroy() throws Exception {
		System.out.println("Card Service Destroyed");
		
	}

	@Override
	public void afterPropertiesSet() throws Exception {
		System.out.println("afterPropertiesSet()");
		System.out.println(typeOfCard);
		System.out.println(digit);
		
	}
	
